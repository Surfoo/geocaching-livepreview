{
    "name": "geocaching-livepreview",
    "version": "1.0.0",
    "description": "Geocaching Live Preview",
    "scripts": {
        "watch": "bun build --watch --minify src/app.js --sourcemap=inline --outfile=public/app.bundle.js",
        "build": "bun build         --minify src/app.js --sourcemap=inline --outfile=public/app.bundle.js",
        "lint": "biome lint src",
        "check": "biome check src",
        "fix": "biome check --write --unsafe src",
        "prepare": "git config core.hooksPath .githooks"
    },
    "author": "Surfoo <surfooo@gmail.com>",
    "license": "ISC",
    "dependencies": {
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/theme-one-dark": "^6.1.3",
        "codemirror": "^6.0.2",
        "i18next": "^26.3.6",
        "i18next-fetch-backend": "^8.0.0",
        "normalize.css": "^8.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "~2.5.3"
    }
}
